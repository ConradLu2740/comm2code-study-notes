# ============================================================
# .dockerignore —— 减少构建上下文体积，加快 docker build 速度
# ------------------------------------------------------------
# 效果：避免把 target/、.git/、.idea/ 这类大文件 COPY 进镜像。
# 这些文件对构建没用，反而会让构建上下文几百 MB，
# 拖慢 docker build 的上传阶段。
# ============================================================

# Maven 构建产物（最终镜像从 builder 阶段 COPY target/*.jar，无需重复 COPY）
target/
**/target/

# Git 元数据
.git/
.gitignore
.gitattributes

# IDE 配置
.idea/
.vscode/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
.factorypath

# 日志 / 临时文件
*.log
logs/
*.tmp
*.bak

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# Docker 自身文件（避免递归构建）
Dockerfile
docker-compose.yml
.dockerignore

# 文档 / 脚本（不需要进镜像，但本项目保留在仓库里）
# docs/
# README.md
# *.md

# 敏感文件（密码 / 密钥，绝不能进镜像）
.env
.env.*
*.pem
*.key